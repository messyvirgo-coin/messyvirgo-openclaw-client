# Copy to .env and adjust as needed
#
# Model provider API keys (set keys for providers you enable)
BANKR_API_KEY=
OPENROUTER_API_KEY=
BRAVE_API_KEY=

# Git repo to clone for building (set to upstream to track openclaw/openclaw)
OPENCLAW_GIT_REPO=https://github.com/messyvirgo-coin/messyvirgo-openclaw

# Where OpenClaw stores secrets/config/sessions on your host
OPENCLAW_CONFIG_DIR=$HOME/.openclaw-secure

# Root host folder containing one workspace per agent (main, mv-coder, mv-researcher, mv-planner)
OPENCLAW_WORKSPACES_DIR=$HOME/OpenClawWorkspaces

# Default workspace path (derived from OPENCLAW_WORKSPACES_DIR by setup.sh)
# Keep this as "<root>/main" unless you know you need a custom mount target.
OPENCLAW_WORKSPACE_DIR=$HOME/OpenClawWorkspaces/main

# Local ports (bound to 127.0.0.1 in docker-compose.yml)
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# npm cache path used by openclaw-cli in hardened read-only containers.
OPENCLAW_NPM_CACHE_DIR=/tmp/.npm

# npm version baked into the runtime image for plugin installs.
OPENCLAW_NPM_VERSION=11.11.1

# Keep bind as 'lan' inside the container (ports are still localhost-only on the host)
OPENCLAW_GATEWAY_BIND=lan

# Image tag built by scripts/setup.sh
OPENCLAW_IMAGE=openclaw-secure:local

# If empty, setup.sh generates a random token and writes it here
OPENCLAW_GATEWAY_TOKEN=

# Optional: install extra apt packages during image build (space-separated)
# Includes jq by default for JSON parsing in helper scripts.
OPENCLAW_DOCKER_APT_PACKAGES=jq

# Where to clone OpenClaw source for builds (optional)
OPENCLAW_SRC_DIR=$HOME/.openclaw-secure/openclaw-src
