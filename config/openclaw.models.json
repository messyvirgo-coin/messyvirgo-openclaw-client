{
  "models": {
    "mode": "merge",
    "providers": {
      "bankr": {
        "baseUrl": "https://llm.bankr.bot/v1",
        "apiKey": "${BANKR_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "kimi-k2.5",
            "name": "Kimi K2.5"
          },
          {
            "id": "gpt-5-mini",
            "name": "GPT-5 Mini"
          },
          {
            "id": "qwen3-coder",
            "name": "Qwen3 Coder"
          },
          {
            "id": "gemini-3-flash",
            "name": "Gemini 3 Flash"
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "bankr/gpt-5-mini"
      },
      "models": {
        "bankr/gpt-5-mini": { "alias": "mini" },
        "bankr/kimi-k2.5": { "alias": "kimi" },
        "bankr/qwen3-coder": { "alias": "coder" },
        "bankr/gemini-3-flash": { "alias": "flash" }
      }
    }
  }
}
