# Copy to .env.api-keys and fill in. These are merged into .env by scripts/up.sh
# so they survive setup.sh overwriting .env (e.g. after OpenClaw updates).
# cp env.api-keys.example .env.api-keys
#
# OpenAI (for openai/* models)
# OPENAI_API_KEY=sk-...
#
# OpenRouter (for openrouter/* models)
# OPENROUTER_API_KEY=sk-or-...
#
# X Monitor dashboard + x-api skill (twitterapi.io)
# XAPI_IO_API_KEY=
#
# Moltbook skill (macro searches, etc.)
# MOLTBOOK_API_KEY=
#
# Social Narrative skill (token-social-and-narrative-analysis)
# MESSYVIRGO_API_KEY=mvk_...
#
# Web search (Brave Search) — for web_search tool
# BRAVE_API_KEY=
#
# Bankr skill (run ./scripts/setup-bankr.sh after setting so config.json is updated)
# BANKR_API_KEY=bk_...
#
# Optional
# DASHBOARD_X_PORT=18788
# GITHUB_TOKEN=
# GIT_PAT=
# OPENCLAW_WATCHDOG_TELEGRAM_BOT_TOKEN=
# OPENCLAW_WATCHDOG_TELEGRAM_CHAT_ID=
